PORT=3000

# Real OpenAI key - never expose this to team clients
OPENAI_API_KEY=sk-...

# Supabase project - service role key required to update usage counters server-side
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Comma-separated list of models teams are allowed to call through the proxy.
# Defaults to "gpt-5-nano,gpt-4o-mini" if unset.
ALLOWED_MODELS=gpt-5-nano,gpt-4o-mini

# USD price per 1M tokens for each allowed model, as JSON: {"model":{"input":X,"output":Y}}.
# Merged over the built-in defaults - only needed to add a model or override a price.
# Every model in ALLOWED_MODELS must have pricing (built-in or here) or the server won't start.
# MODEL_PRICING={"gpt-4o-mini":{"input":0.15,"output":0.6}}

# Secret used to sign dashboard login session JWTs - use a long random string
JWT_SECRET=

# USD->KRW rate used to show a KRW figure alongside USD on the dashboards.
# OpenAI bills in USD only, so this is a local conversion - keep it current.
# Defaults to 1400 if unset.
# USD_KRW_RATE=1400
